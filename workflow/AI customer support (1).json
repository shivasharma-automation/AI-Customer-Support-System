        "subject": "=Support Request Received - {{ $json.ticket_id }}",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\n\nbody{\n    font-family:Arial,sans-serif;\n    background:#f5f7fb;\n    margin:0;\n    padding:30px;\n}\n\n.container{\n    max-width:700px;\n    margin:auto;\n    background:white;\n    border-radius:12px;\n    padding:35px;\n    box-shadow:0 2px 10px rgba(0,0,0,.08);\n}\n\nh1{\n    color:#2563eb;\n    margin-bottom:10px;\n}\n\np{\n    line-height:1.7;\n    color:#444;\n}\n\ntable{\n    width:100%;\n    border-collapse:collapse;\n    margin-top:25px;\n}\n\ntd{\n    border:1px solid #e5e7eb;\n    padding:12px;\n}\n\nth{\n    background:#2563eb;\n    color:white;\n    padding:12px;\n}\n\n.footer{\n    margin-top:35px;\n    font-size:13px;\n    color:#777;\n    border-top:1px solid #eee;\n    padding-top:20px;\n}\n\n</style>\n</head>\n\n<body>\n\n<div class=\"container\">\n\n<h1>Support Request Received ✅</h1>\n\n<p>Hello <strong>{{ $json.customer_name }}</strong>,</p>\n\n<p>\nThank you for contacting <strong>{{ $json.company }}</strong>.\nYour support request has been received successfully.\n</p>\n\n<table>\n\n<tr>\n<th colspan=\"2\">\nSupport Ticket Details\n</th>\n</tr>\n\n<tr>\n<td><strong>Ticket ID</strong></td>\n<td>{{ $json.ticket_id }}</td>\n</tr>\n\n<tr>\n<td><strong>Status</strong></td>\n<td>{{ $json.status }}</td>\n</tr>\n\n<tr>\n<td><strong>Category</strong></td>\n<td>{{ $json.category }}</td>\n</tr>\n\n<tr>\n<td><strong>Priority</strong></td>\n<td>{{ $json.priority }}</td>\n</tr>\n\n<tr>\n<td><strong>Summary</strong></td>\n<td>{{ $json.summary }}</td>\n</tr>\n\n</table>\n\n<p style=\"margin-top:25px;\">\nOur AI assistant has analyzed your request, and our support team will review it shortly.\n</p>\n\n<p>\nThank you for choosing <strong>{{ $json.company }}</strong>.\n</p>\n\n<p>\nBest Regards,<br>\n<strong>{{ $json.company }} Support Team</strong>\n</p>\n\n<div class=\"footer\">\n\nThis is an automated acknowledgement email generated by the AI Customer Support System.\n\n</div>\n\n</div>\n\n</body>\n</html>",
