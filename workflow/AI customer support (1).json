        "jsCode": "const data = $json;\n\n// Current date & time\nconst now = new Date();\n\n// Format: YYYYMMDD\nconst date =\n  now.getFullYear().toString() +\n  String(now.getMonth() + 1).padStart(2, \"0\") +\n  String(now.getDate()).padStart(2, \"0\");\n\n// Generate Ticket ID\nconst ticketId = `TKT-${date}-${Math.floor(1000 + Math.random() * 9000)}`;\n\nreturn {\n  json: {\n    ...data,\n    ticket_id: ticketId,\n    created_at: now.toISOString()\n  }\n};"
